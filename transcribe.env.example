# Провайдер транскрипции голоса. Варианты: elevenlabs | openai | mistral
TRANSCRIBE_PROVIDER=elevenlabs

# ElevenLabs Scribe (рекомендуется — лучшее качество для русского)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_STT_MODEL=scribe_v2

# ElevenLabs TTS (голосовые ответы)
ELEVENLABS_TTS_VOICE=JBFqnCBsd6RMkjVDRZzb   # George — multilingual
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5        # Flash: 75ms, 32 языка
TTS_DAILY_LIMIT_CHARS=50000                   # ~$2.50/день

# OpenAI Whisper (альтернатива)
# TRANSCRIBE_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_TRANSCRIBE_MODEL=whisper-1

# Mistral Voxtral (альтернатива)
# TRANSCRIBE_PROVIDER=mistral
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MISTRAL_TRANSCRIBE_MODEL=voxtral-mini-latest
